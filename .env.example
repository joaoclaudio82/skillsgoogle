# Copie para .env e preencha. O .env NAO vai para o Git (ver .gitignore).

# Chave gratuita do Google AI Studio: https://aistudio.google.com/apikey
# Sem ela, os exemplos rodam em MODO MOCK (resposta simulada, offline, sem custo).
GOOGLE_API_KEY=

# Modelo do Gemini a usar. Ajuste para o modelo atual conforme a skill `gemini-api`.
GEMINI_MODEL=gemini-2.5-flash
